# =============================
# 本地敏感配置模板
# 复制此文件为 application-local.properties 并填入你的真实值
# =============================

# 数据库
spring.datasource.url=jdbc:mysql://localhost:3306/school_lost_found?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
spring.datasource.username=root
spring.datasource.password=你的数据库密码

# Redis
spring.data.redis.password=你的Redis密码

# JWT 密钥（建议32位以上随机字符串）
jwt.secret=你的JWT密钥

# 阿里云 OSS
oss.access-key-id=你的AccessKeyId
oss.access-key-secret=你的AccessKeySecret

# 智谱 AI
zhipu.api.key=你的智谱APIKey
